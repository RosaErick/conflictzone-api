# Copy to ".env" on the server and fill in real values. Never commit the real .env.

# Generate a strong key:  python -c "import secrets; print(secrets.token_urlsafe(50))"
DJANGO_SECRET_KEY=change-me

# Must be False in production.
DJANGO_DEBUG=False

# Public IP and/or domain of the Oracle VM (comma-separated, no spaces).
# Example: DJANGO_ALLOWED_HOSTS=140.238.10.20,api.meudominio.com
DJANGO_ALLOWED_HOSTS=YOUR_PUBLIC_IP

# Fogo Cruzado API credentials.
FOGO_CRUZADO_EMAIL=you@example.com
FOGO_CRUZADO_PASSWORD=your-password

# Gunicorn worker count (rule of thumb: 2 x vCPU + 1).
GUNICORN_WORKERS=3
